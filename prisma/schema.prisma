generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String               @id @default(uuid())
  name                String               @unique
  dbName              String               @unique @map("db_name")
  shardId             String?              @map("shard_id")
  adminEmail          String?              @map("admin_email")
  plan                String
  defaultPwd          String?              @map("default_pwd")
  // UI Settings
  backgroundColor     String?              @default("#ffffff") @map("background_color")
  textColor           String?              @default("#1e293b") @map("text_color")
  heroBackgroundColor String?              @default("#f8fafc") @map("hero_background_color")
  overallTextColor    String?              @default("#475569") @map("overall_text_color")
  createdAt           DateTime             @default(now()) @map("created_at")
  adminContacts       TenantAdminContact[]

  @@map("tenants")
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("patients")
}

model Appointment {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  doctorId  String   @map("doctor_id")
  time      DateTime
  status    String   @default("Scheduled")

  @@map("appointments")
}

model Encounter {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  doctorId  String   @map("doctor_id")
  diagnosis String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("encounters")
}

model Prescription {
  id          String @id @default(uuid())
  encounterId String @map("encounter_id")
  drugName    String @map("drug_name")

  @@map("prescriptions")
}

model Bill {
  id        String @id @default(uuid())
  patientId String @map("patient_id")
  total     Float
  status    String @default("Pending")

  @@map("bills")
}

model TenantAdminContact {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_admin_contacts")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   // Fallback role
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  
  userRoles    UserRole[]

  @@map("users")
}

// --- RBAC CORE TABLES ---

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  menus       RoleMenu[]
  permissions RolePermission[]
  users       UserRole[]

  @@map("rbac_roles")
}

model Menu {
  id        String   @id @default(uuid())
  label     String
  path      String
  icon      String?
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  roles     RoleMenu[]

  @@map("rbac_menus")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  roles       RolePermission[]

  @@map("rbac_permissions")
}

model RoleMenu {
  roleId String @map("role_id")
  menuId String @map("menu_id")
  role   Role   @relation(fields: [roleId], references: [id])
  menu   Menu   @relation(fields: [menuId], references: [id])

  @@id([roleId, menuId])
  @@map("rbac_role_menus")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("rbac_role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("rbac_user_roles")
}